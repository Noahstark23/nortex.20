// NORTEX INC. - REAL MONEY PROTOCOL SCHEMA
// Expense & B2BOrder models for Real Business Logic

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==========================================
// CORE BUSINESS ENTITIES
// ==========================================

model Tenant {
  id                   String    @id @default(cuid())
  businessName         String
  type                 String    @default("FERRETERIA") // FERRETERIA | PULPERIA | LENDER | RETAIL
  taxId                String    @unique
  slug                 String?   @unique // URL amigable para catálogo público (ej: "ferreteria-jose")
  walletBalance        Decimal   @default(0) @db.Decimal(12, 2)
  creditLimit          Decimal   @default(0) @db.Decimal(12, 2)
  creditScore          Int       @default(0)
  subscriptionStatus   String    @default("TRIAL") // TRIAL | ACTIVE | PAST_DUE | CANCELLED
  stripeCustomerId     String? // Stripe Customer ID (cus_xxx)
  stripeSubscriptionId String? // Stripe Subscription ID (sub_xxx)
  subscriptionEndsAt   DateTime? // Fecha de vencimiento de la suscripción activa
  trialEndsAt          DateTime? // Fecha límite del trial gratuito (14 días desde registro)
  theftAlertThreshold  Decimal   @default(500) @db.Decimal(10, 2)
  // Costo de entrega plano del catálogo público (lo fija el negocio; el
  // cliente NUNCA lo manda — se calcula server-side al crear el Pedido).
  deliveryFee          Decimal   @default(0) @db.Decimal(10, 2)
  // Inventario: si true, las ventas/salidas pueden dejar el stock en negativo
  // (negocios que venden sin contar; el Kardex refleja la realidad). Default false.
  allowNegativeStock   Boolean   @default(false)
  // Campos Fiscales DGI
  address              String? // Dirección fiscal
  phone                String? // Teléfono del negocio
  dgiAuthCode          String? // Código autorización DGI (AIMS-xxxx)
  dgiAuthDate          DateTime? // Fecha de autorización DGI
  createdAt            DateTime  @default(now())

  users            User[]
  customers        Customer[]
  suppliers        Supplier[]
  employees        Employee[]
  sales            Sale[]
  shifts           Shift[]
  auditLogs        AuditLog[]
  expenses         Expense[]
  b2bOrders        B2BOrder[]
  products         Product[]
  productBatches   ProductBatch[]
  kardexMovements  KardexMovement[]
  stockCounts      StockCount[]
  purchases        Purchase[]
  purchaseOrders   PurchaseOrder[]
  manualPayments   ManualPayment[]
  quotations       Quotation[]
  invitations      Invitation[]
  cashMovements    CashMovement[]
  productReturns   ProductReturn[]
  accounts         Account[]
  journalEntries   JournalEntry[]
  fiscalRetentions FiscalRetention[]
  invoiceSeries    InvoiceSeries[]
  publicOrders     PublicOrder[]
  capitalLoans     CapitalLoan[]

  // HR Module
  leaveRequests          LeaveRequest[]
  payrollRuns            PayrollRun[]
  payrollLines           PayrollLine[]
  salaryAdvances         SalaryAdvance[]
  terminationSettlements TerminationSettlement[]

  // Delivery module
  motorizados Motorizado[]
  pedidos     Pedido[]

  // WhatsApp channel
  whatsappSessions        WhatsappSession[]
  whatsappInboundMessages WhatsappInboundMessage[]
}

model User {
  id        String    @id @default(cuid())
  tenantId  String
  email     String?   @unique // Optional: some users created via PIN invitation have no email
  password  String
  name      String
  role      String    @default("EMPLOYEE") // OWNER, ADMIN, MANAGER, CASHIER, VIEWER
  status    String    @default("ACTIVE") // ACTIVE, DISABLED
  lastLogin DateTime?
  invitedBy String?
  createdAt DateTime  @default(now())

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  shifts          Shift[]
  payments        Payment[]
  auditLogs       AuditLog[]
  productsCreated Product[]
  kardexMovements KardexMovement[]
  stockCounts     StockCount[]
  passwordResets  PasswordReset[]
  cashMovements   CashMovement[]
  employeeProfile Employee?
  loansAssigned   Loan[]           @relation("LoanCollector")
  whatsappNumber  String?          @unique @db.VarChar(20)
  whatsappSession WhatsappSession?

  @@index([tenantId])
}

// ==========================================
// INVITACIONES DE EQUIPO
// ==========================================

model Invitation {
  id        String   @id @default(cuid())
  tenantId  String
  email     String
  role      String // MANAGER, CASHIER, VIEWER
  token     String   @unique
  status    String   @default("PENDING") // PENDING, ACCEPTED, EXPIRED
  invitedBy String // userId del que invitó
  createdAt DateTime @default(now())
  expiresAt DateTime // 48 horas después de creación

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([token])
}

// ==========================================
// RECUPERACIÓN DE CONTRASEÑA
// ==========================================

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([token])
}

model Customer {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  taxId       String?
  phone       String?
  email       String?
  address     String?  @db.Text
  creditLimit Decimal  @default(0) @db.Decimal(10, 2)
  currentDebt Decimal  @default(0) @db.Decimal(10, 2)
  isBlocked   Boolean  @default(false)
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  sales  Sale[]

  loans Loan[]

  @@index([tenantId])
}

model Supplier {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  ruc         String?
  contactName String?
  phone       String?
  email       String?
  address     String?  @db.Text
  category    String?
  createdAt   DateTime @default(now())

  tenant             Tenant     @relation(fields: [tenantId], references: [id])
  purchases          Purchase[]
  purchaseOrders     PurchaseOrder[]
  defaultForProducts Product[]  @relation("DefaultSupplier")

  @@index([tenantId])
}

// ==========================================
// COMPRAS & CUENTAS POR PAGAR
// ==========================================

model Purchase {
  id            String    @id @default(cuid())
  tenantId      String
  supplierId    String
  invoiceNumber String // # Factura del proveedor
  date          DateTime  @default(now())
  dueDate       DateTime? // Fecha de vencimiento (para crédito)
  subtotal      Decimal   @db.Decimal(12, 2)
  tax           Decimal   @default(0) @db.Decimal(12, 2)
  total         Decimal   @db.Decimal(12, 2)
  status        String    @default("COMPLETED") // COMPLETED | PENDING_PAYMENT
  paymentMethod String // CASH | CREDIT
  notes         String?   @db.Text
  createdBy     String
  createdAt     DateTime  @default(now())
  // Recepción de una Orden de Compra (null = compra directa sin OC previa)
  purchaseOrderId String?

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  supplier      Supplier       @relation(fields: [supplierId], references: [id])
  items         PurchaseItem[]
  capitalLoan   CapitalLoan?
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  @@index([tenantId])
  @@index([purchaseOrderId])
  @@index([supplierId])
  @@index([status])
}

model PurchaseItem {
  id          String    @id @default(cuid())
  purchaseId  String
  productId   String
  productName String // Snapshot del nombre al momento de compra
  quantity    Int
  unitCost    Decimal   @db.Decimal(10, 2)
  totalCost   Decimal   @db.Decimal(10, 2)
  batchNumber String? // Número de lote ingresado en la compra
  expiryDate  DateTime? // Fecha de vencimiento ingresada en la compra

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([purchaseId])
}

// ==========================================
// ÓRDENES DE COMPRA (procurement: pedido → aprobación → recepción)
// ==========================================

model PurchaseOrder {
  id          String    @id @default(cuid())
  tenantId    String
  supplierId  String
  orderNumber String // correlativo legible por tenant (OC-0001)
  status      String    @default("DRAFT") // DRAFT | APPROVED | PARTIALLY_RECEIVED | RECEIVED | CANCELLED
  notes       String?   @db.Text
  expectedDate DateTime? // fecha esperada de entrega
  createdBy   String
  approvedBy  String? // userId que aprobó (traza, sin relación)
  approvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier            @relation(fields: [supplierId], references: [id])
  items    PurchaseOrderItem[]
  receipts Purchase[] // recepciones (parciales o total) generadas contra esta OC

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([supplierId])
  @@index([status])
}

model PurchaseOrderItem {
  id               String  @id @default(cuid())
  purchaseOrderId  String
  productId        String
  productName      String // snapshot del nombre al crear la OC
  quantityOrdered  Float
  quantityReceived Float   @default(0)
  unitCost         Decimal @db.Decimal(10, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId])
  @@index([productId])
}

model Employee {
  id                    String   @id @default(cuid())
  tenantId              String
  userId                String?  @unique // Link a User (para el EmployeeProfile real interactivo)
  firstName             String
  lastName              String
  role                  String
  pin                   String   @default("0000")
  cedula                String? // Cédula de identidad nicaragüense
  inss                  String? // Número INSS del empleado
  baseSalary            Decimal  @db.Decimal(10, 2)
  commissionRate        Decimal  @default(0) @db.Decimal(5, 2)
  phone                 String?
  vacationDays          Float    @default(0) // Días de vacaciones acumulados
  accumulatedThirteenth Decimal  @default(0) @db.Decimal(10, 2) // Aguinaldo acumulado
  hireDate              DateTime @default(now())
  bankAccount           String?
  status                String   @default("ACTIVE") // ACTIVE, SUSPENDED, TERMINATED
  jornada               String   @default("DIURNA") // DIURNA 8h | NOCTURNA 7h | MIXTA 7.5h (Art. 51)

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])
  sales    Sale[]
  shifts   Shift[]
  payrolls Payroll[]

  // HR Relations
  leaveRequests         LeaveRequest[]
  salaryAdvances        SalaryAdvance[]
  terminationSettlement TerminationSettlement?
  payrollLines          PayrollLine[]
  aguinaldos            Aguinaldo[]
  contracts             EmploymentContract[]
  judicialDeductions    JudicialDeduction[]

  @@index([tenantId])
}

// Deducción judicial recurrente — pensión alimenticia / embargo (Art. 88 Ley
// 185; tienen prioridad legal sobre otras deducciones). Monto fijo o % del
// salario disponible (neto de deducciones de ley).
model JudicialDeduction {
  id          String    @id @default(cuid())
  tenantId    String
  employeeId  String
  type        String // PENSION_ALIMENTICIA | EMBARGO | OTRO
  amount      Decimal?  @db.Decimal(10, 2) // monto fijo (alternativa a percentage)
  percentage  Float? // % del salario disponible (alternativa a amount)
  beneficiary String? // a quién se paga / N° de expediente judicial
  priority    Int       @default(1) // menor = mayor prioridad (pensión = 1)
  status      String    @default("ACTIVE") // ACTIVE | ENDED
  startDate   DateTime  @default(now())
  endDate     DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([employeeId])
}

// Calendario de feriados (Art. 66 Ley 185). Los nacionales se siembran por
// tenant/año; el negocio puede agregar fiestas locales (national = false).
model Holiday {
  id        String   @id @default(cuid())
  tenantId  String
  date      DateTime @db.Date
  name      String
  national  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([tenantId, date])
  @@index([tenantId])
}

// Expediente digital — contrato de trabajo (Art. 19-28 Ley 185; el MITRAB
// exige contrato escrito). Un empleado puede tener varios (renovaciones).
model EmploymentContract {
  id           String    @id @default(cuid())
  tenantId     String
  employeeId   String
  type         String // INDETERMINADO | DETERMINADO | POR_OBRA
  startDate    DateTime
  endDate      DateTime? // para DETERMINADO / POR_OBRA
  probationEnd DateTime? // fin del período de prueba (hasta 30 días, Art. 28)
  salary       Decimal   @db.Decimal(10, 2)
  position     String? // cargo
  notes        String?   @db.Text
  status       String    @default("ACTIVE") // ACTIVE | ENDED
  createdBy    String
  createdAt    DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([employeeId])
}

// Corrida de aguinaldo (treceavo mes) — Art. 93-95 Ley 185.
// Una fila por empleado y año de corrida (período dic[year-1] → nov[year]).
model Aguinaldo {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  year          Int
  diasLaborados Int
  baseSalary    Decimal  @db.Decimal(10, 2)
  monto         Decimal  @db.Decimal(10, 2)
  status        String   @default("PAGADO")
  paidAt        DateTime @default(now())
  createdAt     DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, year])
  @@index([tenantId])
}

// ==========================================
// NÓMINA NICARAGÜENSE (LEY 185 CÓDIGO DEL TRABAJO)
// ==========================================

model Payroll {
  id         String @id @default(cuid())
  tenantId   String
  employeeId String
  month      Int // 1-12
  year       Int

  // Ingresos
  grossSalary Decimal @db.Decimal(10, 2) // Salario Base
  commissions Decimal @default(0) @db.Decimal(10, 2)
  totalIncome Decimal @db.Decimal(10, 2) // Bruto total

  // Deducciones de Ley
  inssLaboral     Decimal @db.Decimal(10, 2) // 7% (INSS Laboral)
  irLaboral       Decimal @db.Decimal(10, 2) // IR según tabla progresiva DGI
  totalDeductions Decimal @db.Decimal(10, 2)

  // Neto
  netSalary Decimal @db.Decimal(10, 2) // Neto a recibir

  // Aportes Patronales (costo empresa)
  inssPatronal Decimal @db.Decimal(10, 2) // 22.5% (INSS Patronal)
  inatec       Decimal @db.Decimal(10, 2) // 2% (INATEC)

  // Fase A RRHH: horas extra (Art. 62 Ley 185, al doble) y descuento de adelantos
  overtimePay      Decimal @default(0) @db.Decimal(10, 2)
  horasExtra       Float   @default(0)
  advanceDeduction Decimal @default(0) @db.Decimal(10, 2)

  // Fase C2: feriados trabajados (Art. 68, recargo del 100% por día)
  holidayPay   Decimal @default(0) @db.Decimal(10, 2)
  diasFeriados Float   @default(0)

  // Fase A p2: ausencias sin goce de salario (descuentan días trabajados)
  absenceDeduction Decimal @default(0) @db.Decimal(10, 2)
  diasAusencia     Float   @default(0)

  // Fase C4: deducciones judiciales (pensión alimenticia / embargos)
  judicialDeduction Decimal @default(0) @db.Decimal(10, 2)

  status    String    @default("PENDIENTE") // PENDIENTE | PAGADO
  paidAt    DateTime?
  createdAt DateTime  @default(now())

  employee         Employee        @relation(fields: [employeeId], references: [id])
  advancesDeducted SalaryAdvance[]

  @@unique([employeeId, month, year])
  @@index([tenantId])
  @@index([employeeId])
}

// ==========================================
// REPORTES FISCALES DGI NICARAGUA
// ==========================================

model TaxReport {
  id       String @id @default(cuid())
  tenantId String
  month    Int
  year     Int

  // Ventas
  totalSales        Decimal @db.Decimal(12, 2)
  totalIVACollected Decimal @db.Decimal(12, 2) // IVA cobrado en ventas
  totalIVAPaid      Decimal @db.Decimal(12, 2) // IVA pagado en compras (crédito fiscal)

  // Impuestos a pagar
  ivaNeto     Decimal @db.Decimal(12, 2) // IVA Ventas - IVA Compras
  anticipoIR  Decimal @db.Decimal(12, 2) // 1% sobre ventas netas
  imiAlcaldia Decimal @db.Decimal(12, 2) // 1% impuesto municipal
  totalToPay  Decimal @db.Decimal(12, 2)

  generatedAt DateTime @default(now())

  @@unique([tenantId, month, year])
  @@index([tenantId])
}

model Sale {
  id             String    @id @default(cuid())
  tenantId       String
  total          Decimal   @db.Decimal(10, 2)
  status         String
  paymentMethod  String
  customerName   String?
  customerId     String?
  employeeId     String?
  balance        Decimal   @default(0) @db.Decimal(10, 2)
  dueDate        DateTime?
  shiftId        String?
  createdAt      DateTime  @default(now())
  globalDiscount Float     @default(0)
  // Facturación DGI
  invoiceNumber  Int? // Consecutivo controlado (1, 2, 3...)
  invoiceSeries  String? // Serie: "A", "B" (por sucursal)
  // PWA Offline Sync — UUID generado en el cliente para idempotencia
  offlineId      String?   @unique

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  customer       Customer?       @relation(fields: [customerId], references: [id])
  employee       Employee?       @relation(fields: [employeeId], references: [id])
  shift          Shift?          @relation(fields: [shiftId], references: [id])
  items          SaleItem[]
  payments       Payment[]
  productReturns ProductReturn[]
  pedidos        Pedido[]

  @@index([tenantId])
  @@index([customerId])
  @@index([employeeId])
  @@index([shiftId])
}

model SaleItem {
  id          String  @id @default(cuid())
  saleId      String
  productId   String
  quantity    Float
  priceAtSale Decimal @db.Decimal(10, 2)
  costAtSale  Decimal @db.Decimal(10, 2)
  discount    Float   @default(0) // Item discount percentage (0-100)

  sale Sale @relation(fields: [saleId], references: [id])

  @@index([saleId])
}

model Payment {
  id          String   @id @default(cuid())
  saleId      String
  amount      Decimal  @db.Decimal(10, 2)
  method      String
  collectedBy String
  createdAt   DateTime @default(now())

  sale Sale @relation(fields: [saleId], references: [id])
  user User @relation(fields: [collectedBy], references: [id])

  @@index([saleId])
}

model Shift {
  id                 String    @id @default(cuid())
  tenantId           String
  userId             String
  employeeId         String? // Empleado que abrió la caja (PIN)
  initialCash        Decimal   @db.Decimal(10, 2)
  finalCashDeclared  Decimal?  @db.Decimal(10, 2)
  systemExpectedCash Decimal?  @db.Decimal(10, 2)
  difference         Decimal?  @db.Decimal(10, 2)
  regularHours       Float     @default(0)
  overtimeHours      Float     @default(0)
  nightHours         Float     @default(0)
  status             String
  startTime          DateTime  @default(now())
  endTime            DateTime?

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  user          User           @relation(fields: [userId], references: [id])
  employee      Employee?      @relation(fields: [employeeId], references: [id])
  sales         Sale[]
  cashMovements CashMovement[]
  RouteExpense  RouteExpense[]

  @@index([tenantId])
  @@index([userId])
  @@index([employeeId])
}

model Expense {
  id          String   @id @default(cuid())
  tenantId    String
  amount      Decimal  @db.Decimal(12, 2)
  description String   @db.Text
  category    String
  createdAt   DateTime @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  cashMovement CashMovement?

  @@index([tenantId])
  @@index([category])
}

// ==========================================
// 💰 CASH MOVEMENTS (ENTRADAS/SALIDAS DE CAJA)
// ==========================================

model CashMovement {
  id          String    @id @default(cuid())
  tenantId    String
  shiftId     String
  userId      String
  type        String // IN | OUT
  amount      Decimal   @db.Decimal(10, 2)
  currency    String    @default("NIO") // NIO | USD
  category    String // GASTO_OPERATIVO | PAGO_PROVEEDOR | RETIRO_PERSONAL | CAMBIO | INYECCION_CAPITAL | AJUSTE
  description String    @db.Text
  expenseId   String?   @unique // Auto-linked Expense (for OUT movements)
  isVoided    Boolean   @default(false) // Soft delete: movimiento anulado
  voidReason  String?   @db.Text
  voidedAt    DateTime?
  voidedBy    String?
  createdAt   DateTime  @default(now())

  // Integridad del libro (tamper-evidence) — cadena de hash por tenant.
  // Nullable: filas legacy quedan sin firmar hasta el backfill.
  // La anulación (isVoided/voidReason/...) NO entra en la firma: el registro
  // económico es inmutable; el void es una anotación posterior.
  seq       Int? // Posición monotónica en la cadena del tenant
  prevHash  String? // Firma del movimiento anterior (encadenamiento)
  signature String? // HMAC-SHA256 de los campos inmutables (versionado "vN:...")

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  shift   Shift    @relation(fields: [shiftId], references: [id])
  user    User     @relation(fields: [userId], references: [id])
  expense Expense? @relation(fields: [expenseId], references: [id])

  @@unique([tenantId, seq])
  @@index([tenantId])
  @@index([shiftId])
  @@index([createdAt])
}

// Cabeza de la cadena del libro por tenant. El UPDATE con increment toma
// row-lock de InnoDB → serializa los appends del tenant (sin carreras de seq).
model LedgerHead {
  tenantId  String   @id
  lastSeq   Int      @default(0)
  lastHash  String   @default("GENESIS")
  updatedAt DateTime @updatedAt
}

// ==========================================
// WHATSAPP — Agente IA (RAG) · infraestructura Fase 1
// tenantId como escalar (sin relación) para no tocar el bloque de
// relaciones de Tenant; el aislamiento se aplica en la capa de servicio.
// ==========================================

// Mapea un número de WhatsApp (phone_number_id de Meta) → tenant.
// Un solo Meta App de plataforma (WHATSAPP_APP_SECRET global verifica la
// firma de TODO webhook); cada tenant trae su número/WABA y su access token
// de envío (cifrado con crypto.encryptField).
model WhatsAppChannel {
  id             String   @id @default(cuid())
  tenantId       String
  phoneNumberId  String   @unique // ID del número en Meta — routing de entrada
  wabaId         String? // WhatsApp Business Account
  displayPhone   String? // +505… legible
  accessTokenEnc String   @db.Text // token de envío, CIFRADO (enc:v1:…)
  botScope       String   @default("B2C") // B2C | B2B | BOTH
  defaultMode    String   @default("BOT") // BOT | HUMAN
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@index([tenantId])
}

// Una conversación por (tenant, waId). Mantiene el estado de handoff.
model WhatsAppConversation {
  id             String    @id @default(cuid())
  tenantId       String
  waId           String // número del cliente final (E.164 sin +)
  customerId     String? // resuelto contra Customer (null = onboarding pendiente)
  status         String    @default("BOT") // BOT | HUMAN | CLOSED
  lastInboundAt  DateTime?
  lastOutboundAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  messages WhatsAppMessage[]

  @@unique([tenantId, waId])
  @@index([tenantId, status])
}

model WhatsAppMessage {
  id             String   @id @default(cuid())
  conversationId String
  tenantId       String
  direction      String // IN | OUT
  waMessageId    String?  @unique // id de Meta — idempotencia de entrada
  type           String   @default("text")
  body           String   @db.Text
  status         String? // sent | delivered | read | failed (salientes)
  createdAt      DateTime @default(now())

  conversation WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([conversationId])
}

model B2BOrder {
  id        String   @id @default(cuid())
  tenantId  String
  total     Decimal  @db.Decimal(12, 2)
  items     Json
  status    String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  action    String
  details   String?  @db.Text
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
}

// ==========================================
// INVENTORY MANAGEMENT (Professional Kardex System)
// ==========================================

model Product {
  id       String @id @default(cuid())
  tenantId String

  // Identificación
  name        String
  sku         String // Código único del producto
  description String? @db.Text
  category    String?

  // Precios
  price Float // Precio de venta
  cost  Float // Costo de compra

  // Inventario
  stock    Float  @default(0)
  minStock Float  @default(0) // Stock mínimo para alerta
  unit     String @default("unidad") // kg, litro, unidad, caja, etc.

  // Reposición (Bodeguero B2)
  reorderPoint Float @default(0) // Punto de reorden: stock ≤ esto → reponer
  maxStock     Float @default(0) // Stock objetivo/máximo (para sugerir cuánto comprar)

  // Proveedor por defecto (Bodeguero C2) — agrupa/prellena la orden de compra
  defaultSupplierId String?

  // Catálogo Público
  isPublished Boolean @default(false) // Visible en catálogo público
  imageUrl    String? // URL de imagen del producto

  // Control de Lotes
  requiresBatchTracking Boolean @default(false)

  // Auditoría
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String

  // Relaciones
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator         User             @relation(fields: [createdBy], references: [id])
  kardexMovements KardexMovement[]
  pedidoItems     PedidoItem[]
  batches         ProductBatch[]
  stockCountItems StockCountItem[]
  purchaseOrderItems PurchaseOrderItem[]
  defaultSupplier Supplier?        @relation("DefaultSupplier", fields: [defaultSupplierId], references: [id], onDelete: SetNull)

  @@unique([tenantId, sku])
  @@index([defaultSupplierId])
  @@index([tenantId])
  @@index([category])
  @@fulltext([name, category])
}

model KardexMovement {
  id       String @id @default(cuid())
  tenantId String

  // Producto afectado
  productId String

  // Tipo de movimiento
  type     String // IN (entrada), OUT (salida), SALE (venta), ADJUSTMENT (ajuste), RETURN (devolución)
  quantity Float // Cantidad (positiva para entradas, negativa para salidas)

  // Stock antes/después para auditoría
  stockBefore Float
  stockAfter  Float

  // Referencia opcional (ID de venta, compra, etc.)
  referenceId   String?
  referenceType String? // SALE, PURCHASE, ADJUSTMENT, INITIAL

  // Auditoría
  reason String?  @db.Text
  date   DateTime @default(now())
  userId String

  // Relaciones
  tenant  Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id])
  batchId String?
  batch   ProductBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([tenantId])
  @@index([date])
  @@index([type])
  @@index([batchId])
}

// ==========================================
// CONTROL DE LOTES Y VENCIMIENTOS
// ==========================================

model ProductBatch {
  id          String   @id @default(cuid())
  tenantId    String
  productId   String
  batchNumber String // Número de lote
  expiryDate  DateTime // Fecha de vencimiento
  stock       Float    @default(0) // Stock restante del lote
  createdAt   DateTime @default(now())

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  kardexMovements KardexMovement[]

  @@unique([productId, batchNumber])
  @@index([tenantId])
  @@index([productId])
  @@index([expiryDate])
}

// ==========================================
// TOMA FÍSICA / CONTEO CÍCLICO (Bodeguero B1)
// ==========================================

model StockCount {
  id        String    @id @default(cuid())
  tenantId  String
  status    String    @default("OPEN") // OPEN | CLOSED | CANCELLED
  scope     String    @default("ALL") // ALL | CATEGORY
  category  String? // si scope=CATEGORY
  notes     String?   @db.Text
  createdBy String
  createdAt DateTime  @default(now())
  closedAt  DateTime?
  closedBy  String? // userId que cerró (sin relación, solo traza)

  tenant  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator User             @relation(fields: [createdBy], references: [id])
  items   StockCountItem[]

  @@index([tenantId])
  @@index([status])
}

model StockCountItem {
  id        String    @id @default(cuid())
  countId   String
  productId String
  expected  Float // snapshot del stock del sistema al crear el conteo
  counted   Float? // conteo físico capturado (null = aún no contado)
  diff      Float     @default(0) // counted - expected (calculado al cerrar)
  countedAt DateTime?

  count   StockCount @relation(fields: [countId], references: [id], onDelete: Cascade)
  product Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([countId, productId])
  @@index([countId])
  @@index([productId])
}

// ==========================================
// PAGOS MANUALES (DEPÓSITO / TRANSFERENCIA)
// ==========================================

model ManualPayment {
  id              String    @id @default(cuid())
  tenantId        String
  amount          Decimal   @db.Decimal(10, 2)
  currency        String    @default("USD") // USD | NIO
  bank            String // Banco destino (BAC, Lafise, etc.)
  referenceNumber String // Número de referencia del voucher
  proofUrl        String?   @db.Text // URL/ruta de la foto del comprobante
  notes           String?   @db.Text
  status          String    @default("PENDING") // PENDING | APPROVED | REJECTED
  rejectionReason String?   @db.Text
  reviewedBy      String? // userId del admin que revisó
  reviewedAt      DateTime?
  createdAt       DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([status])
}

// ==========================================
// QUOTATIONS (COTIZACIONES)
// ==========================================

model Quotation {
  id           String   @id @default(cuid())
  tenantId     String
  customerName String
  customerRuc  String?
  subtotal     Decimal  @db.Decimal(10, 2)
  tax          Decimal  @db.Decimal(10, 2)
  total        Decimal  @db.Decimal(10, 2)
  status       String   @default("SENT") // SENT | CONVERTED | EXPIRED
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  tenant Tenant          @relation(fields: [tenantId], references: [id])
  items  QuotationItem[]

  @@index([tenantId])
}

model QuotationItem {
  id          String  @id @default(cuid())
  quotationId String
  productId   String
  quantity    Int
  price       Decimal @db.Decimal(10, 2)
  name        String // Snapshot name

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
}

// ==========================================
// 🔄 DEVOLUCIONES / NOTAS DE CRÉDITO
// ==========================================

model ProductReturn {
  id        String   @id @default(cuid())
  tenantId  String
  saleId    String
  total     Decimal  @db.Decimal(10, 2) // Total del reembolso
  reason    String   @db.Text
  items     Json // [{productId, name, quantity, price}]
  createdBy String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  sale   Sale   @relation(fields: [saleId], references: [id])

  @@index([tenantId])
  @@index([saleId])
}

// ==========================================
// 📊 CONTABILIDAD DE PARTIDA DOBLE (NIIF PyMES)
// ==========================================

model Account {
  id       String  @id @default(cuid())
  tenantId String
  code     String // "1.1.1", "4.1.1", etc.
  name     String // "Caja General", "Inventario", "Ventas"
  type     String // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE
  subtype  String? // CURRENT_ASSET, FIXED_ASSET, CURRENT_LIABILITY, etc.
  balance  Decimal @default(0) @db.Decimal(14, 2)
  isSystem Boolean @default(true) // Cuentas del sistema (no borrables)

  tenant Tenant        @relation(fields: [tenantId], references: [id])
  lines  JournalLine[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([type])
}

model JournalEntry {
  id            String   @id @default(cuid())
  tenantId      String
  date          DateTime @default(now())
  description   String   @db.Text
  referenceId   String? // Sale.id, Purchase.id, etc.
  referenceType String? // SALE, PURCHASE, EXPENSE, PAYROLL, ADJUSTMENT, RETURN, PAYMENT
  isAutomatic   Boolean  @default(true)
  createdBy     String
  createdAt     DateTime @default(now())

  tenant Tenant        @relation(fields: [tenantId], references: [id])
  lines  JournalLine[]

  @@index([tenantId])
  @@index([referenceId])
  @@index([date])
}

model JournalLine {
  id             String  @id @default(cuid())
  journalEntryId String
  accountId      String
  debit          Decimal @default(0) @db.Decimal(14, 2)
  credit         Decimal @default(0) @db.Decimal(14, 2)

  entry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
}

model FiscalRetention {
  id          String   @id @default(cuid())
  tenantId    String
  type        String // IR_2PCT, IMI_1PCT, IVA_RETENIDO
  amount      Decimal  @db.Decimal(10, 2)
  baseAmount  Decimal  @db.Decimal(10, 2)
  supplierId  String?
  purchaseId  String?
  description String   @db.Text
  period      String // "2026-02"
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([period])
}

// ==========================================
// 🧾 FACTURACIÓN COMPUTARIZADA DGI
// ==========================================

model InvoiceSeries {
  id         String  @id @default(cuid())
  tenantId   String
  series     String  @default("A") // Serie de factura (A, B, etc.)
  lastNumber Int     @default(0) // Último consecutivo emitido
  rangeStart Int     @default(1) // Rango autorizado DGI: desde
  rangeEnd   Int     @default(999999) // Rango autorizado DGI: hasta
  isActive   Boolean @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, series])
  @@index([tenantId])
}

// ==========================================
// HR: NICALABOR ENGINE & MICRO-LENDING
// ==========================================

model LeaveRequest {
  id         String   @id @default(cuid())
  tenantId   String
  employeeId String
  type       String // SICK, VACATION, UNPAID, MATERNITY
  startDate  DateTime
  endDate    DateTime
  status     String   @default("PENDING") // PENDING, APPROVED, REJECTED
  reason     String?  @db.Text
  createdAt  DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([employeeId])
}

model PayrollRun {
  id          String   @id @default(cuid())
  tenantId    String
  periodStart DateTime
  periodEnd   DateTime
  totalAmount Decimal  @default(0) @db.Decimal(10, 2)
  status      String   @default("DRAFT") // DRAFT, APPROVED, PAID

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  payrollLines PayrollLine[]

  @@index([tenantId])
}

model PayrollLine {
  id                String  @id @default(cuid())
  tenantId          String
  payrollRunId      String
  employeeId        String
  basePay           Decimal @db.Decimal(10, 2)
  overtimePay       Decimal @default(0) @db.Decimal(10, 2)
  commissions       Decimal @default(0) @db.Decimal(10, 2)
  bonuses           Decimal @default(0) @db.Decimal(10, 2)
  inssDeduction     Decimal @default(0) @db.Decimal(10, 2)
  irDeduction       Decimal @default(0) @db.Decimal(10, 2)
  advanceDeductions Decimal @default(0) @db.Decimal(10, 2)
  netPay            Decimal @db.Decimal(10, 2)

  tenant       Tenant          @relation(fields: [tenantId], references: [id])
  payrollRun   PayrollRun      @relation(fields: [payrollRunId], references: [id])
  employee     Employee        @relation(fields: [employeeId], references: [id])
  advancesPaid SalaryAdvance[]

  @@index([tenantId])
  @@index([payrollRunId])
  @@index([employeeId])
}

model SalaryAdvance {
  id                 String  @id @default(cuid())
  tenantId           String
  employeeId         String
  amount             Decimal @db.Decimal(10, 2)
  fee                Decimal @default(0) @db.Decimal(10, 2)
  status             String  @default("PENDING") // PENDING, APPROVED, REJECTED, DEDUCTED
  repaymentPayrollId String?
  // Fase A RRHH: enlaza el adelanto a la nómina (Payroll) donde se descontó.
  payrollId          String?

  tenant           Tenant       @relation(fields: [tenantId], references: [id])
  employee         Employee     @relation(fields: [employeeId], references: [id])
  repaymentPayroll PayrollLine? @relation(fields: [repaymentPayrollId], references: [id])
  payroll          Payroll?     @relation(fields: [payrollId], references: [id])

  @@index([tenantId])
  @@index([employeeId])
  @@index([repaymentPayrollId])
  @@index([payrollId])
}

model TerminationSettlement {
  id              String   @id @default(cuid())
  tenantId        String
  employeeId      String   @unique
  terminationDate DateTime
  reason          String // RESIGNATION, DISMISSAL, JUSTIFIED
  aguinaldoAmount Decimal  @default(0) @db.Decimal(10, 2)
  vacationAmount  Decimal  @default(0) @db.Decimal(10, 2)
  severanceAmount Decimal  @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal  @default(0) @db.Decimal(10, 2)

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
}

// ==========================================
// 🌐 PEDIDOS PÚBLICOS (PORTAL WEB)
// ==========================================

model PublicOrder {
  id            String   @id @default(cuid())
  tenantId      String
  customerName  String
  customerPhone String?
  items         Json // [{productId, name, quantity, price}]
  status        String   @default("PENDING") // PENDING | CONVERTED
  createdAt     DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([status])
}

// ==========================================
// 💰 NORTEX CAPITAL (EMBEDDED LENDING)
// ==========================================

model CapitalLoan {
  id               String   @id @default(cuid())
  tenantId         String
  amount           Decimal  @db.Decimal(12, 2) // Monto prestado
  interestRate     Decimal  @db.Decimal(5, 4) // 0.05 = 5%
  totalDue         Decimal  @db.Decimal(12, 2) // amount * (1 + rate)
  dueDate          DateTime // Vencimiento
  status           String   @default("ACTIVE") // ACTIVE | PAID | DEFAULTED
  linkedPurchaseId String?  @unique // Compra financiada (1:1)
  createdAt        DateTime @default(now())

  // Tamper-evidence: HMAC de los términos inmutables del préstamo al originarse
  signature String?

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  purchase Purchase? @relation(fields: [linkedPurchaseId], references: [id])

  @@index([tenantId])
  @@index([status])
}

model Motorizado {
  id                   String   @id @default(uuid())
  tenantId             String? // Opcional: Si es nulo, es un motorizado global de Nortex
  tipoFlota            String   @default("PROPIA") // "PROPIA" (de la ferretería) o "NORTEX" (freelance)
  nombre               String   @db.VarChar(100)
  telefono             String   @db.VarChar(20)
  zonaCobertura        String   @db.VarChar(100)
  activo               Boolean  @default(true)
  walletId             String?  @unique // ¡Su propia cuenta bancaria Nortex!
  calificacionPromedio Float    @default(5.0)
  vehiculoPlaca        String?  @db.VarChar(20)
  createdAt            DateTime @default(now())

  // ── Red NORTEX: registro público + KYC + login teléfono+PIN ──
  cedula          String? @db.VarChar(25) // Cédula de identidad (KYC)
  pinHash         String? // bcrypt del PIN — login del driver (reemplaza el magic-link)
  kycStatus       String  @default("PENDIENTE") // PENDIENTE | APROBADO | RECHAZADO
  kycNota         String? @db.Text // Motivo de rechazo / notas del revisor
  fotoCedulaUrl   String? // KYC: foto de la cédula (Cloudinary)
  fotoVehiculoUrl String? // KYC: foto de la moto con placa visible (Cloudinary)

  // ── FASE 3: Wallet del Real Money Protocol ──
  // PROYECCIÓN del saldo — la verdad es el libro firmado (DriverWalletMovement).
  // Se verifica recomputando contra la cadena; jamás se firma el saldo mutable.
  walletBalance Decimal @default(0) @db.Decimal(12, 2)

  tenant      Tenant?                @relation(fields: [tenantId], references: [id])
  pedidos     Pedido[]
  movimientos DriverWalletMovement[]

  @@index([tenantId])
  @@index([telefono])
  @@index([kycStatus])
}

// ══════════════════════════════════════════════════════════════════════════
// FASE A — Períodos fiscales (bloqueo del cierre)
// Una fila existe SOLO cuando el período fue cerrado (o reabierto). Sin fila →
// el período se trata como ABIERTO (no rompe los flujos existentes). El guard
// assertPeriodOpen bloquea cualquier asiento cuya fecha caiga en CLOSED.
// ══════════════════════════════════════════════════════════════════════════
model FiscalPeriod {
  id           String    @id @default(cuid())
  tenantId     String
  year         Int
  month        Int // 1-12
  status       String    @default("CLOSED") // CLOSED | OPEN (reabierto)
  closedBy     String?
  closedAt     DateTime?
  reopenedBy   String?
  reopenedAt   DateTime?
  reopenReason String?   @db.Text
  updatedAt    DateTime  @updatedAt

  @@unique([tenantId, year, month])
  @@index([tenantId])
}

// ══════════════════════════════════════════════════════════════════════════
// FASE B — Cumplimiento (parte 1): parametrización + retenciones sufridas
// ══════════════════════════════════════════════════════════════════════════

// B4 — Tasas fiscales por tenant. Las constantes del código pasan a defaults;
// el contador ajusta según el contribuyente (INSS 21.5/<50 emp · 22.5/≥50,
// Anticipo IR/PMD 1-3%, IMI por alcaldía).
model TaxConfig {
  tenantId         String   @id
  inssPatronalRate Decimal  @default(0.225) @db.Decimal(6, 4)
  anticipoIrRate   Decimal  @default(0.0100) @db.Decimal(6, 4)
  imiRate          Decimal  @default(0.0100) @db.Decimal(6, 4)
  salarioMinimo    Decimal  @default(0) @db.Decimal(12, 2)
  updatedAt        DateTime @updatedAt
}

// B6 — Tipo de cambio (deslizamiento del córdoba). Mata el 36.56 hardcodeado.
// Se usa la fila con fecha <= hoy más reciente. Carga manual o semilla BCN.
model ExchangeRate {
  id        String   @id @default(cuid())
  tenantId  String
  fecha     DateTime @db.Date
  rate      Decimal  @db.Decimal(10, 4) // C$ por US$
  source    String   @default("MANUAL") // MANUAL | BCN
  createdAt DateTime @default(now())

  @@unique([tenantId, fecha])
  @@index([tenantId, fecha])
}

// B1 — Retención SUFRIDA: el cliente (empresa/Estado) le retuvo IR 2% / IMI 1%
// al negocio. Es CRÉDITO contra el Anticipo IR del mes → deja de pagar de más.
model RetencionSufrida {
  id               String   @id @default(cuid())
  tenantId         String
  fecha            DateTime
  clienteRetenedor String   @db.VarChar(160)
  tipo             String // IR_2 | IMI_1
  baseAmount       Decimal  @db.Decimal(12, 2)
  amount           Decimal  @db.Decimal(12, 2)
  numeroConstancia String?  @db.VarChar(60)
  saleId           String?
  createdBy        String
  createdAt        DateTime @default(now())

  @@index([tenantId, fecha])
}

// ══════════════════════════════════════════════════════════════════════════
// FASE B parte 2 — Activos fijos + depreciación (Ley 822)
// ══════════════════════════════════════════════════════════════════════════
model FixedAsset {
  id               String   @id @default(cuid())
  tenantId         String
  nombre           String   @db.VarChar(160)
  categoria        String // EDIFICIO | VEHICULO | MAQUINARIA | MOBILIARIO | COMPUTO | OTRO
  costo            Decimal  @db.Decimal(14, 2)
  fechaAdquisicion DateTime @db.Date
  vidaUtilMeses    Int // método de línea recta (cuota = costo / vidaUtilMeses)

  depreciacionAcumulada Decimal @default(0) @db.Decimal(14, 2)
  mesesDepreciados      Int     @default(0)
  // "YYYY-MM" de la última cuota posteada → idempotencia del corrido mensual.
  ultimoPeriodoDep      String?
  estado                String  @default("ACTIVO") // ACTIVO | BAJA

  createdBy String
  createdAt DateTime @default(now())

  movimientos DepreciationEntry[]

  @@index([tenantId])
  @@index([estado])
}

// Cuota mensual posteada (auditoría + idempotencia dura por @@unique).
model DepreciationEntry {
  id        String   @id @default(cuid())
  assetId   String
  tenantId  String
  year      Int
  month     Int
  amount    Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(now())

  asset FixedAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, year, month])
  @@index([tenantId])
}

// ══════════════════════════════════════════════════════════════════════════
// FASE C — Panel del contador: estado de obligaciones del mes (checklist)
// ══════════════════════════════════════════════════════════════════════════
model ObligationStatus {
  id        String    @id @default(cuid())
  tenantId  String
  year      Int
  month     Int
  key       String // IVA | ANTICIPO_IR | IMI | INSS | INATEC
  declarado Boolean   @default(false)
  markedBy  String?
  markedAt  DateTime?
  updatedAt DateTime  @updatedAt

  @@unique([tenantId, year, month, key])
  @@index([tenantId])
}

// el UPDATE con increment toma row-lock → serializa los appends del driver).
model DriverLedgerHead {
  motorizadoId String   @id
  lastSeq      Int      @default(0)
  lastHash     String   @default("GENESIS")
  updatedAt    DateTime @updatedAt
}

// Libro inmutable del wallet del repartidor (tamper-evidence).
// amount: + acredita (comisión por entrega), − debita (pago de Nortex al driver).
model DriverWalletMovement {
  id           String   @id @default(cuid())
  motorizadoId String
  tenantId     String? // Negocio para el que se repartió (null en pagos/ajustes de plataforma)
  pedidoId     String?  @unique // 1 entrega = 1 comisión (idempotencia a nivel de DB)
  type         String // COMISION_ENTREGA | PAGO_NORTEX | AJUSTE
  amount       Decimal  @db.Decimal(12, 2)
  descripcion  String   @db.Text
  createdAt    DateTime @default(now())

  // Cadena firmada (mismo esquema que CashMovement): null = legacy/sin claves.
  seq       Int?
  prevHash  String?
  signature String?

  motorizado Motorizado @relation(fields: [motorizadoId], references: [id])

  @@unique([motorizadoId, seq])
  @@index([motorizadoId])
  @@index([type])
}

model Pedido {
  id                  String    @id @default(uuid())
  tenantId            String
  clienteNombre       String    @db.VarChar(100)
  clienteTelefono     String    @db.VarChar(20)
  direccionEntrega    String    @db.Text
  referenciaDireccion String?   @db.Text
  motorizadoId        String?
  estado              String    @default("pendiente") // pendiente, preparando, en_camino, entregado, cancelado
  total               Decimal   @db.Decimal(10, 2)
  costoEntrega        Decimal   @db.Decimal(10, 2)
  facturaId           String?
  notas               String?   @db.Text
  createdAt           DateTime  @default(now())
  entregadoAt         DateTime?
  distanciaEstimada   Float? // Distancia en KM
  tiempoEntregaReal   Int? // Tiempo en minutos

  tenant     Tenant           @relation(fields: [tenantId], references: [id])
  motorizado Motorizado?      @relation(fields: [motorizadoId], references: [id])
  factura    Sale?            @relation(fields: [facturaId], references: [id])
  items      PedidoItem[]
  eventos    TrackingEvento[]

  @@index([tenantId])
  @@index([motorizadoId])
  @@index([facturaId])
}

model PedidoItem {
  id             String  @id @default(uuid())
  pedidoId       String
  productoId     String
  cantidad       Int
  precioUnitario Decimal @db.Decimal(10, 2)
  subtotal       Decimal @db.Decimal(10, 2)

  pedido   Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  producto Product @relation(fields: [productoId], references: [id])

  @@index([pedidoId])
  @@index([productoId])
}

model TrackingEvento {
  id        String   @id @default(uuid())
  pedidoId  String
  estado    String
  nota      String?  @db.Text
  lat       Float? // GPS tracking
  lng       Float? // GPS tracking
  createdAt DateTime @default(now())

  pedido Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@index([pedidoId])
}

// ==========================================
// 🦄 MÓDULO NORTEX PRESTAMISTAS (AISLADO)
// ==========================================

enum LoanType {
  INFORMAL_FLAT // Préstamo de calle (Gota a Gota), interés fijo desde el día 1
  FORMAL_AMORTIZED // Préstamo de financiera, interés sobre saldo
}

enum PaymentFrequency {
  DAILY // Diario (Típico informal)
  WEEKLY // Semanal
  BIWEEKLY // Quincenal
  MONTHLY // Mensual (Típico financiera)
}

enum LoanStatus {
  PENDING
  ACTIVE
  DEFAULTED // En mora / incobrable
  PAID_OFF // Pagado totalmente
}

model Loan {
  id       String  @id @default(uuid())
  // Relaciones (Opcionales si el cliente no está en el sistema Nortex aún)
  tenantId String? // Si le prestamos a una Ferretería Nortex
  lenderId String // El Tenant que está prestando la plata

  // Enlace CRM
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  // Datos del Cliente Externo (Para préstamos de calle)
  clientName    String
  clientPhone   String?
  clientAddress String?

  // Configuración del Dinero
  type      LoanType         @default(INFORMAL_FLAT)
  frequency PaymentFrequency @default(DAILY)

  principalAmount  Decimal @db.Decimal(12, 2) // Capital prestado
  interestRate     Decimal @db.Decimal(5, 2) // Tasa de interés (%)
  totalToRepay     Decimal @db.Decimal(12, 2) // Capital + Interés (Flat)
  balanceRemaining Decimal @db.Decimal(12, 2) // Cuánto debe a hoy

  installments      Int // Número de cuotas (ej: 30 días)
  installmentAmount Decimal @db.Decimal(10, 2) // De a cuánto toca la cuota

  status      LoanStatus @default(ACTIVE)
  disbursedAt DateTime   @default(now())
  dueDate     DateTime // Fecha límite final

  // Historial de cobros
  payments Repayment[]

  // Plan de cuotas (Cobranza B2)
  schedule LoanInstallment[]

  // Asignación de Ruta (Motorizado encargado de cobrar)
  assignedToId String?
  assignedTo   User?   @relation("LoanCollector", fields: [assignedToId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Cuota del plan de pago de un préstamo (Cobranza B2)
model LoanInstallment {
  id         String   @id @default(uuid())
  loanId     String
  number     Int // Nº de cuota (1..n)
  dueDate    DateTime // Vencimiento de la cuota
  amountDue  Decimal  @db.Decimal(10, 2)
  amountPaid Decimal  @default(0) @db.Decimal(10, 2)
  status     String   @default("PENDING") // PENDING | PARTIAL | PAID
  createdAt  DateTime @default(now())

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@unique([loanId, number])
  @@index([loanId])
  @@index([dueDate])
}

model Repayment {
  id     String @id @default(uuid())
  loanId String
  loan   Loan   @relation(fields: [loanId], references: [id], onDelete: Cascade)

  amountPaid  Decimal  @db.Decimal(10, 2)
  paymentDate DateTime @default(now())
  collectedBy String? // Nombre del cobrador de la moto

  notes     String?  @db.Text
  createdAt DateTime @default(now())
}

model RouteExpense {
  id          String   @id @default(uuid())
  lenderId    String // El Tenant prestamista
  collectedBy String // Nombre del motorizado
  amount      Decimal  @db.Decimal(10, 2)
  description String // "Gasolina Moto 1", "Pinchazo llanta"
  shiftId     String? // Turno vinculado
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  shift Shift? @relation(fields: [shiftId], references: [id])
}

// Entrega de efectivo del cobrador a la bóveda del prestamista (Cobranza A3)
model CollectorDeposit {
  id            String   @id @default(uuid())
  lenderId      String // El Tenant prestamista que recibe la entrega
  collectorId   String? // userId del cobrador (si está en el sistema)
  collectorName String? // Nombre del cobrador (respaldo de auditoría)
  amount        Decimal  @db.Decimal(12, 2) // Efectivo entregado
  notes         String?  @db.Text
  receivedBy    String // userId del jefe que registró la entrega
  date          DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([lenderId])
}

// ==========================================
// 📱 CANAL WHATSAPP
// ==========================================

model WhatsappSession {
  id          String   @id @default(cuid())
  userId      String   @unique
  tenantId    String
  threadId    String? // ID del hilo conversacional del LLM
  state       String   @default("CHAT")
  // Estados: CHAT, PENDING_CONFIRMATION, PROCESSING, ERROR
  pendingData Json? // Draft de venta antes de confirmar
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model WhatsappInboundMessage {
  id        String   @id @default(cuid())
  messageId String   @unique
  // ID de Meta (wamid.xxx). Sirve como dedup key.
  tenantId  String
  status    String   @default("PROCESSING")
  // Estados: PROCESSING, PROCESSED, FAILED.
  // Default PROCESSING para que retries puedan recuperar
  // mensajes que quedaron a medio procesar por crash.
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([createdAt]) // Para job de cleanup mensual
}
